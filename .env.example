# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Backend (read by dotenvy in Rust sim-server) ---
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
SUPABASE_JWKS_X=...
SUPABASE_JWKS_Y=...

# --- Frontend (only VITE_* vars are exposed to client code by Vite) ---
# Required for the card-hand login UI in src/cardHand/cardHandView.ts —
# without them the browser renders "Login unavailable" / "Supabase env missing".
VITE_SUPABASE_URL=https://PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Optional: backend URL the frontend talks to. Defaults to http://127.0.0.1:8080.
VITE_ABUTOWN_BACKEND_URL=http://127.0.0.1:8080

# Comma-separated browser origins allowed to call the API (CORS). Unset =
# fail-closed (no cross-origin requests). Dev/e2e use http://127.0.0.1:5173.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
