# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Backend (read by dotenvy in Rust sim-server) ---
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=verify-full
PGSSLROOTCERT=/absolute/path/to/prod-supabase.cer
SUPABASE_URL=https://PROJECT.supabase.co

# --- Frontend (only VITE_* vars are exposed to client code by Vite) ---
# Required for the card-hand login UI in src/cardHand/cardHandView.ts.
VITE_SUPABASE_URL=https://PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Backend URL the card hand talks to. Defaults to http://127.0.0.1:8080.
VITE_ABUTOWN_BACKEND_URL=http://127.0.0.1:8080

# Live traffic (instanced car layer). Set this on a static/Vercel deploy to
# point the car layer at the deployed sim-server /traffic WS gateway. WITHOUT
# it the layer is opt-in via ?traffic=1 and defaults to ws://localhost:8790, so
# a plain deploy shows no cars. Use wss:// on an https:// site.
VITE_TRAFFIC_WS=wss://abutown-abutopia.fly.dev/traffic

# Live world channel (citizens + vitals HUD). Same pattern; opt-in via ?live=1.
VITE_LIVE_WS=wss://abutown-abutopia.fly.dev/live

# Comma-separated browser origins allowed to call the API (CORS). Unset =
# fail-closed. Dev uses http://127.0.0.1:5173.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
