  "devDependencies": {
    "@bufbuild/buf": "^1.45.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@types/node": "^25.7.0",
    "@types/suncalc": "^1.9.2",
    "@types/three": "^0.185.0",
    "playwright": "^1.60.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
