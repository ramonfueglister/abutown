{
  "name": "abutown",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:stack": "node scripts/run-dev-stack.mjs dev",
    "preview": "vite preview --host 127.0.0.1",
    "preview:stack": "node scripts/run-dev-stack.mjs preview",
    "build": "tsc --noEmit && vite build",
    "assets:pak128": "node scripts/import-pak128-assets.mjs",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "npm run build && playwright test",
    "generate:city-network": "node --import tsx/esm scripts/generate-city-network.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
