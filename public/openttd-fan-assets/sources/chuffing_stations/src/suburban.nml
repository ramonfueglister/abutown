/***************************************************************************/
/********************* SUBURBAN PLATFORMS **********************************/
/***************************************************************************/

/*******************************************/
/***** BASIC PLATFORM **********************/
/*******************************************/

/** PLATFORM LEFT **/

spriteset (suburban_basic_platform_left, "src/graphics/stations_suburban_empty.png") {
    [  10, 10, 64, 64, -31, -32 ]
    [  80, 10, 64, 64, -31, -32 ]
}

spriteset (suburban_basic_platform_left_half, "src/graphics/stations_suburban_half.png") {
    [  10, 10, 64, 64, -31, -32 ]
    [  80, 10, 64, 64, -31, -32 ]
}

spriteset (suburban_basic_platform_left_full, "src/graphics/stations_suburban_full.png") {
    [  10, 10, 64, 64, -31, -32 ]
    [  80, 10, 64, 64, -31, -32 ]
}

spritelayout suburban_basic_platform_left_sw_ne(a) {
    ground {
        sprite: GROUNDSPRITE_RAIL_X;
    }
    building {
        sprite:         DEFAULT(0);
        xoffset:        0;
        yoffset:        0;
        zoffset:        0;
        xextent:        16;
        yextent:        5;
        zextent:        16;
        recolour_mode:  RECOLOUR_REMAP;
        palette:        PALETTE_USE_DEFAULT;
    }
}

spritelayout suburban_basic_platform_left_se_nw(a) {
    ground {
        sprite: GROUNDSPRITE_RAIL_Y;
    }
    building {
        sprite:         DEFAULT(1);
        xoffset:        11;
        yoffset:        0;
        zoffset:        0;
        xextent:        5;
        yextent:        16;
        zextent:        16;
        recolour_mode:  RECOLOUR_REMAP;
        palette:        PALETTE_USE_DEFAULT;
    }
}

spritegroup group_suburban_basic_left {
    little: [suburban_basic_platform_left, suburban_basic_platform_left_half];
    lots:   suburban_basic_platform_left_full;
}

item(FEAT_STATIONS, suburban_basic_platform_left_station) {
    property {
        class:                  "_SBR";
        classname:              string(STR_NAME_STATCLASS_SUBURBAN_PLATFORMS);
        name:                   string(STR_NAME_STATION_PLATFORM_BASIC);
        cargo_threshold:        param_set_cargo_threshold*160;
    }
    graphics {
        sprite_layouts: [suburban_basic_platform_left_sw_ne(0), suburban_basic_platform_left_se_nw(0)];
        select_tile_type: 2;
        PASS: group_suburban_basic_left;
        purchase: suburban_basic_platform_left;
        suburban_basic_platform_left;
    }
}

